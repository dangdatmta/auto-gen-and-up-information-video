UPLOAD_ENABLED=false

# Đường dẫn file nhạc nền (bắt buộc khi render video)
# macOS/Linux: BACKGROUND_AUDIO_PATH=/Users/yourname/music/background01.mp3
# Windows:     BACKGROUND_AUDIO_PATH=E:\20.tainguyen\background01.mp3
# Nếu để trống, mặc định tìm tại assets/background01.mp3 trong thư mục repo
BACKGROUND_AUDIO_PATH=
BACKGROUND_VOLUME=0.42
BACKGROUND_VOLUME_WITH_TTS=0.25

# Hook voiceover cho từng cảnh tin bằng VieNeu-TTS
# Cài SDK trong Python env dùng để chạy: pip install vieneu
HOOK_TTS_ENABLED=false
HOOK_TTS_PROVIDER=vieneu
HOOK_TTS_PYTHON=
HOOK_TTS_START_OFFSET=0.45
HOOK_TTS_MAX_SECONDS=6.8
HOOK_TTS_VOLUME=1.0
VIENEU_MODE=standard
VIENEU_EMOTION=natural
VIENEU_VOICE_ID=
VIENEU_API_BASE=
VIENEU_MODEL_NAME=pnnbao-ump/VieNeu-TTS-v2

# Facebook Page Reels
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
