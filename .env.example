UPLOAD_ENABLED=false

# Đường dẫn file nhạc nền (bắt buộc khi render video)
# macOS/Linux: BACKGROUND_AUDIO_PATH=/Users/yourname/music/background01.mp3
# Windows:     BACKGROUND_AUDIO_PATH=E:\20.tainguyen\background01.mp3
# Nếu để trống, mặc định tìm tại assets/background01.mp3 trong thư mục repo
BACKGROUND_AUDIO_PATH=

# Facebook Page Reels
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
